{
	"name": "scintilla-chat",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.3.14",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"cf:dev": "turbo run dev",
		"check": "turbo run check",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.4",
		"turbo": "^2.9.0",
		"typescript": "^6.0.3",
		"wrangler": "^4.0.0"
	},
	"allowScripts": {
		"wrangler": true
	}
}
