{
	"name": "scintilla-chat",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@babel/plugin-proposal-decorators": "^8.0.2",
		"@cloudflare/workers-types": "^5.20260716.1",
		"@rolldown/plugin-babel": "^0.2.3",
		"@sveltejs/adapter-cloudflare": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"remult": "^3.3.16",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"wrangler": "^4.0.0"
	},
	"allowScripts": {
		"@sveltejs/kit": true,
		"esbuild": true,
		"wrangler": true
	},
	"dependencies": {
		"@better-auth/cli": "^1.4.21",
		"@nerdfolio/remult-better-auth": "^0.4.3",
		"better-auth": "^1.6.23"
	}
}
