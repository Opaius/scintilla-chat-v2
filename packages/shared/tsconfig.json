{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"experimentalDecorators": true,
		"useDefineForClassFields": false,
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"ignoreDeprecations": "6.0"
	},
	"include": ["src"]
}
